{
  "name": "ipv-cri-ob-front",
  "version": "1.0.0",
  "description": "Open Banking Credential Issuer Frontend",
  "homepage": "https://github.com/govuk-one-login/ipv-cri-ob-front#readme",
  "bugs": {
    "url": "https://github.com/govuk-one-login/ipv-cri-ob-front/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/govuk-one-login/ipv-cri-ob-front.git"
  },
  "license": "MIT",
  "author": "ipv-cri-lime",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check-translation": "node node_modules/@govuk-one-login/di-ipv-cri-common-express/scripts/checkTranslations.js '../../../../src/locales'",
    "dev": "NODE_ENV=development tsx watch src/index.ts | pino-pretty",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:browser": "bddgen && playwright test",
    "test:browser:ui": "bddgen && playwright test --ui",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.0",
    "@types/express": "4.17.21",
    "@types/express-session": "1.18.2",
    "@types/govuk-frontend": "5.11.0",
    "@types/node": "25.5.0",
    "@types/nunjucks": "3.2.6",
    "@vitest/coverage-v8": "4.1.3",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-perfectionist": "5.7.0",
    "jiti": "2.6.1",
    "pino-pretty": "13.1.3",
    "playwright-bdd": "8.5.0",
    "prettier": "3.8.1",
    "prettier-plugin-jinja-template": "2.1.0",
    "prettier-plugin-organize-imports": "4.3.0",
    "sass-embedded": "1.98.0",
    "testcontainers": "11.13.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.5",
    "vite-plugin-static-copy": "4.0.1",
    "vitest": "4.1.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.1020.0",
    "@govuk-one-login/di-ipv-cri-common-express": "13.1.0",
    "@govuk-one-login/frontend-analytics": "4.0.7",
    "@govuk-one-login/frontend-device-intelligence": "1.2.0",
    "@govuk-one-login/frontend-language-toggle": "2.2.2",
    "@govuk-one-login/frontend-ui": "5.0.1",
    "@govuk-one-login/frontend-vital-signs": "0.1.4",
    "axios": "1.13.6",
    "connect-dynamodb": "3.0.5",
    "dotenv": "17.3.1",
    "express": "4.22.1",
    "express-session": "1.19.0",
    "govuk-frontend": "5.14.0",
    "nunjucks": "3.2.4",
    "zod": "4.3.6"
  },
  "overrides": {
    "hmpo-logger": "8.0.3",
    "hmpo-components": "8.0.6",
    "@govuk-one-login/frontend-language-toggle": "$@govuk-one-login/frontend-language-toggle",
    "@govuk-one-login/frontend-ui": "$@govuk-one-login/frontend-ui"
  }
}
