{% extends "govuk/template.njk" %}
{% set govukRebrand = true %}
{% set assetPath = "/public/rebrand" %}
{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}

{% block head %}
  {% if devServer %}
    <script type="module" src="/@vite/client"></script>
    <link rel="stylesheet" href="/src/assets/scss/stubs.scss" />
  {% else %}
    <link rel="stylesheet" href="/public/stylesheets/stubs.css" />
  {% endif %}
{% endblock %}

{% block pageTitle %}
  Open Banking CRI Stubs
{% endblock %}

{% block bodyStart %}
{% endblock %}

{% block header %}
  {{
    govukHeader({
      rebrand: _rebrand,
      productName: "Open Banking CRI",
      classes: "hazard-border"
    })
  }}
  <div class="govuk-width-container">
    {{
      govukPhaseBanner({
        tag: {
          text: "INTERNAL",
          classes: "govuk-tag--yellow"
        },
        html: 'This is an internal page used for testing – <a class="govuk-link" href="https://home.account.gov.uk/contact-gov-uk-one-login">contact us immediately</a> if you were not expecting to see this'
      })
    }}
  </div>
{% endblock %}

{% block content %}
  {% for f in flash %}
    <div class="stub-flash stub-flash--{{ f.type }}">
      <h3 class="govuk-heading-s govuk-!-margin-bottom-0">{{ f.message.header }}</h3>
      {% if f.message.content %}<pre>{{ f.message.content }}</pre>{% endif %}
    </div>
  {% endfor %}
  {% block mainContent %}
  {% endblock %}
{% endblock %}

{% block footer %}
  {{ super() }}
{% endblock %}

{% block bodyEnd %}
{% endblock %}
